generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductVisibility {
  RETAIL
  WHOLESALE
  BOTH
}

enum PricingLevel {
  C
  D
  E
  F
}

enum RetailOrderStatus {
  PENDING
  CONFIRMED
  PREPARED
  DELIVERED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  OVERDUE
  PARTIAL
}

enum SaleUnit {
  PACK
  UNIT
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  B2B_CLIENT
}

enum BaseUnit {
  PIECE
  KILOGRAM
  LITER
}

enum PackagingType {
  CARTON
  BAG
  CASE
  BOTTLE
  BUCKET
  DRUM
  JAR
  CAN
  OTHER
}

model Product {
  id               String            @id @default(cuid())
  name             String
  sku              String            @unique
  category         String
  sellingPrice     Float
  unitSellingPrice Float?
  priceLevelC      Float?
  priceLevelD      Float?
  priceLevelE      Float?
  priceLevelF      Float?
  visibility       ProductVisibility @default(BOTH)
  imageUrl         String?
  baseUnit         BaseUnit
  packaging        PackagingType
  unitsPerPack     Int               @default(1)
  retailOrderItems RetailOrderItem[]
  orderItems       OrderItem[]
}

model RetailCustomer {
  id        String        @id @default(cuid())
  name      String
  email     String?       @unique
  phone     String        @unique
  password  String
  city      String
  address   String
  isActive  Boolean       @default(true)
  orders    RetailOrder[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model RetailOrder {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  customerId      String
  customer        RetailCustomer    @relation(fields: [customerId], references: [id])
  deliveryName    String
  deliveryPhone   String
  deliveryCity    String
  deliveryAddress String
  status          RetailOrderStatus @default(PENDING)
  totalAmount     Float
  paymentMethod   String            @default("cash_on_delivery")
  notes           String?
  items           RetailOrderItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model RetailOrderItem {
  id          String      @id @default(cuid())
  orderId     String
  order       RetailOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  productName String
  unitPrice   Float
  quantity    Int
  totalPrice  Float
  createdAt   DateTime    @default(now())
}

model DeliverySchedule {
  id            String   @id @default(cuid())
  city          String
  scheduledDate DateTime
  note          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Customer {
  id            String        @id @default(cuid())
  companyName   String
  contactName   String
  email         String?
  phone         String
  city          String
  address       String
  postalCode    String
  country       String
  pricingLevel  PricingLevel?
  isActive      Boolean       @default(true)
  portalAccount User?         @relation("CustomerPortalAccount")
  orders        Order[]
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  role       Role      @default(STAFF)
  isActive   Boolean   @default(true)
  customerId String?   @unique
  customer   Customer? @relation("CustomerPortalAccount", fields: [customerId], references: [id])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  orderDate   DateTime
  status      OrderStatus @default(PENDING)
  totalAmount Float
  notes       String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  saleUnit   SaleUnit @default(PACK)
  unitPrice  Float
  quantity   Int
  discount   Float    @default(0)
  taxRate    Float    @default(20)
  totalPrice Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
