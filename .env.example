# URL of the AlimExpressApp back-end (server-only, used by lib/api-client.ts)
BACKEND_URL="http://localhost:3000"
# Optional: expose to the browser if any client-side fetch is needed (rare; server actions are preferred)
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"

# Shared JWT secret with AlimExpressApp (verify tokens locally for session/middleware checks)
# Must equal one of AUTH_SECRET / RETAIL_JWT_SECRET / B2B_JWT_SECRET set on the back-end.
BACKEND_JWT_SECRET=""

# Database URL is no longer required: this front-end is a pure API client.
# Prisma will be removed in Phase F.I.
